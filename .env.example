# ── AutoApply — Environment Variables Template ────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore for this reason.

# MongoDB Atlas connection string (add /autoapply before the ?)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/autoapply?retryWrites=true&w=majority&appName=Cluster0

# Gmail — use a 16-character App Password, not your real Gmail password
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_TO=your_gmail@gmail.com

# Indeed Publisher API (optional — get free at https://ads.indeed.com/jobroll/xmlfeed)
INDEED_PUBLISHER_ID=your_publisher_id

# Cron schedule (default: every day at 6 AM — uses Asia/Kolkata timezone)
CRON_SCHEDULE=0 6 * * *

# Application limits
MAX_APPLY_PER_DAY=20
MIN_MATCH_SCORE=45

# Your profile (used in email reports)
YOUR_NAME=Your Full Name
YOUR_EMAIL=your_email@gmail.com
YOUR_PHONE=+91-XXXXXXXXXX
YOUR_LINKEDIN=https://linkedin.com/in/your-profile

# Dashboard auth — CHANGE THIS to a long random string before deploying publicly
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SECRET=change_me_to_a_long_random_string

# Port (Render sets this automatically; leave as 3500 for local dev)
PORT=3500
